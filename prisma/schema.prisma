generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- NEXTAUTH REQUIRED TABLES ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// --- VEREIN (SOCIETY) SPECIFIC TABLES ---
enum Role {
  GUEST
  MEMBER
  VORSTAND 
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(GUEST)
  
  accounts      Account[]
  sessions      Session[]
  events        EventAttendee[]
  donations     Donation[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String
  attendees   EventAttendee[]
  createdAt   DateTime @default(now())
}

model EventAttendee {
  eventId String
  userId  String
  
  event   Event @relation(fields: [eventId], references: [id])
  user    User  @relation(fields: [userId], references: [id])

  @@id([eventId, userId])
}

model Donation {
  id        String   @id @default(cuid())
  amount    Float
  message   String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
}

model BoardMember {
  id      String  @id @default(cuid())
  role    String  // e.g., "1. Vorsitzender"
  name    String
  address String?
  phone   String?
  email   String?
  order   Int     @default(0) // Helps us sort them properly (1st, 2nd, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VereinInfo {
  id             String @id @default("1") // We only need 1 row for the whole Verein
  aboutText      String @db.Text
  contactEmail   String
  bankName       String
  iban           String
  bic            String
  registerCourt  String
  registerNumber String

  updatedAt      DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String   @db.Text
  isRead    Boolean  @default(false) // So the board knows if it was answered
  createdAt DateTime @default(now())
}

model PageStat {
  id        String   @id @default(cuid())
  pageName  String   @unique // e.g., "home"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String   // The ID or Email of the user
  userName  String?  // The name of the user
  city      String?
  country   String?
  createdAt DateTime @default(now())
}

model Article {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text // Use @db.Text for long blog posts
  imageUrl    String?  // Optional cover image URL
  isPublished Boolean  @default(false) // True = Public, False = Draft
  
  // Author Info (Saved automatically via Next-Auth)
  authorId    String
  authorName  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}